name: Deploy

# DISABLED. Renamed from deploy.yml to deploy.yml.disabled because GitHub
# Actions only schedules files matching .github/workflows/*.yml.
# To re-enable: `git mv deploy.yml.disabled deploy.yml` and re-publish the
# image to GHCR (also disabled in ci.yml — see that file's git history).
#
# Why disabled: there's no production product to deploy yet. The MCP/agent
# stack works in dev but isn't in a "ship it on every main push" state.
# Keeping the workflow file in tree (not deleting) so we don't have to
# re-derive the deploy plumbing from scratch when we're ready.
#
# BEFORE THIS WORKS, you also need to configure:
#   1. Switch DEPLOY_USER from kshitij to arkos (the service account
#      nmorgan provisioned post-merge of PR #190 follow-ups).
#   2. GitHub repo secret: SSH_PRIVATE_KEY (private key for arkos@ark.mit.edu)
#   3. On ark.mit.edu: the corresponding public key in ~/.ssh/authorized_keys
#      for the arkos user.
#   4. On ark.mit.edu: /home/arkos/arkos/.env file with DB_URL,
#      OPENAI_API_KEY, SMITHERY_API_KEY, etc.
#   5. Either: make the ghcr.io/sgiark/arkos package public
#      OR: run `docker login ghcr.io` once on ark.mit.edu as arkos.
#   6. Verify the server's root disk has space (was 99% full last check).

on:
  push:
    branches: [main]
  workflow_dispatch:

env:
  DEPLOY_HOST: ark.mit.edu
  DEPLOY_USER: kshitij
  IMAGE: ghcr.io/${{ github.repository }}
  CONTAINER_NAME: arkos-app
  APP_PORT: 1112

jobs:
  deploy:
    name: Deploy container to ark.mit.edu
    runs-on: ubuntu-latest
    needs: []

    steps:
      - uses: actions/checkout@v4

      - name: Configure SSH
        run: |
          mkdir -p ~/.ssh
          echo "${{ secrets.SSH_PRIVATE_KEY }}" > ~/.ssh/deploy_key
          chmod 600 ~/.ssh/deploy_key
          ssh-keyscan -H ${{ env.DEPLOY_HOST }} >> ~/.ssh/known_hosts

      - name: Pull and restart container
        run: |
          ssh -i ~/.ssh/deploy_key ${{ env.DEPLOY_USER }}@${{ env.DEPLOY_HOST }} \
            IMAGE="${{ env.IMAGE }}" \
            SHA="${{ github.sha }}" \
            CONTAINER_NAME="${{ env.CONTAINER_NAME }}" \
            APP_PORT="${{ env.APP_PORT }}" \
            'bash -s' <<'DEPLOY_SCRIPT'
            set -e

            echo "=== Pulling image ${IMAGE}:${SHA} ==="
            docker pull "${IMAGE}:${SHA}"

            # Record current image for potential rollback
            PREVIOUS=$(docker inspect --format='{{.Config.Image}}' "${CONTAINER_NAME}" 2>/dev/null || echo "")
            echo "Previous image: ${PREVIOUS:-none}"

            echo "=== Stopping old container ==="
            docker stop "${CONTAINER_NAME}" 2>/dev/null || true
            docker rm "${CONTAINER_NAME}" 2>/dev/null || true

            echo "=== Starting new container ==="
            # --network host lets the container reach SGLang/TEI/Postgres on localhost
            # --env-file loads DB_URL, OPENAI_API_KEY, etc. from the user's .env
            docker run -d \
              --name "${CONTAINER_NAME}" \
              --network host \
              --restart unless-stopped \
              --env-file /home/kshitij/arkos/.env \
              "${IMAGE}:${SHA}"

            echo "=== Waiting for health check ==="
            for i in {1..12}; do
              if curl -sf --max-time 3 "http://localhost:${APP_PORT}/health" > /dev/null; then
                echo "Health check passed!"
                # Save previous image tag for rollback reference
                echo "${PREVIOUS}" > /home/kshitij/arkos/.previous_image
                exit 0
              fi
              echo "Attempt $i/12 failed, waiting 5s..."
              sleep 5
            done

            echo "Health check failed after 60s"
            docker logs --tail 50 "${CONTAINER_NAME}" || true
            exit 1
          DEPLOY_SCRIPT

      - name: Smoke test
        run: |
          ssh -i ~/.ssh/deploy_key ${{ env.DEPLOY_USER }}@${{ env.DEPLOY_HOST }} \
            APP_PORT="${{ env.APP_PORT }}" \
            'bash -s' <<'SMOKE_SCRIPT'
            set -e
            echo "=== Running smoke test ==="

            response=$(curl -sf -X POST "http://localhost:${APP_PORT}/v1/chat/completions" \
              -H "Content-Type: application/json" \
              -d '{"model":"ark-agent","messages":[{"role":"user","content":"Say hello in one word."}]}' \
              --max-time 60)

            echo "$response" | python3 -c "
            import sys, json
            data = json.load(sys.stdin)
            assert 'choices' in data, 'No choices in response'
            content = data['choices'][0]['message']['content']
            assert len(content) > 0, 'Empty response content'
            print(f'Smoke test passed: {content[:100]}')
            "
          SMOKE_SCRIPT

      - name: Rollback on failure
        if: failure()
        run: |
          ssh -i ~/.ssh/deploy_key ${{ env.DEPLOY_USER }}@${{ env.DEPLOY_HOST }} \
            CONTAINER_NAME="${{ env.CONTAINER_NAME }}" \
            'bash -s' <<'ROLLBACK_SCRIPT'
            set -e
            PREVIOUS=$(cat /home/kshitij/arkos/.previous_image 2>/dev/null || echo "")
            if [ -z "$PREVIOUS" ]; then
              echo "No previous image recorded — cannot roll back automatically"
              exit 1
            fi

            echo "=== Rolling back to ${PREVIOUS} ==="
            docker stop "${CONTAINER_NAME}" 2>/dev/null || true
            docker rm "${CONTAINER_NAME}" 2>/dev/null || true
            docker run -d \
              --name "${CONTAINER_NAME}" \
              --network host \
              --restart unless-stopped \
              --env-file /home/kshitij/arkos/.env \
              "${PREVIOUS}"
            echo "Rollback complete"
          ROLLBACK_SCRIPT
